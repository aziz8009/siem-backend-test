# Server
NODE_ENV=development
PORT=3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=backend_user
DB_PASSWORD=secretpassword
DB_NAME=siem_db
DB_POOL_MIN=2
DB_POOL_MAX=10

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX=security-alerts
ELASTICSEARCH_TIMEOUT=30000

# Logging
LOG_LEVEL=info